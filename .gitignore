.sass-cache/
*.css.map
*.sass.map
*.scss.map
public/
static/processed_images/

# Zola auto-writes these into static/ whenever markdown.highlighting.style
# is "class" (regardless of the configured theme/light_theme/dark_theme) —
# unused dead weight here since our own token colours are hand-authored in
# themes/tapestry/sass/css/_code.scss instead of these generated files.
static/giallo*.css

# Read-only upstream reference clone, pinned per specs/terminus-compat-contract.md.
# Not vendored — re-clone at the pinned commit if this directory is missing.
themes/terminus/

# Ignore local Claude configuration overrides
.claude/settings.local.json
.claude/CLAUDE.local.md

# DO NOT ignore these (ensure they are tracked if they exist):
# !.claude/settings.json
# !.claude/launch.json
# !.claude/CLAUDE.md

.env
config.toml.bak
