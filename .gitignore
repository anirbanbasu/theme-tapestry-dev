*.css.map
*.sass.map
*.scss.map
public/
static/processed_images/

# Read-only upstream reference clone, pinned per docs/terminus-compat-contract.md.
# Not vendored — re-clone at the pinned commit if this directory is missing.
themes/terminus/

# Ignore local Claude configuration overrides
.claude/settings.local.json
.claude/CLAUDE.local.md

# DO NOT ignore these (ensure they are tracked if they exist):
# !.claude/settings.json
# !.claude/launch.json
# !.claude/CLAUDE.md

.env

# Node build tooling (KaTeX pre-rendering, see docs/katex-build-pipeline.md).
node_modules/

# Scratch Zola project mirror generated by scripts/render-katex.js on every
# build. Regenerated from content/ + symlinks to the rest of the repo root;
# never hand-edited, never the source of truth.
.katex-build/
